// VNH Business Plan Tool
// Prisma schema with login, role-based access control, department permissions,
// approval comments, version snapshots, and audit history support.
//
// Drop-in path:
//   prisma/schema.prisma
//
// After replacing the existing schema, run:
//   npx prisma generate
//   npx prisma migrate dev --name add_auth_rbac_departments
//
// For production/Render:
//   npx prisma migrate deploy

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  PLANNER
  APPROVER
  REVIEWER
  ACCOUNTING
  FINANCE
  BUDGET_OFFICER
  BUDGET_PLANNER
  DONOR_MANAGER
  VIEWER
}

enum PlanStatus {
  DRAFT
  REVIEW
  RETURNED
  BUDGET_REVIEW
  FINANCE_REVIEW
  BUDGET_CLEARED
  APPROVED
  SUBMITTED
  EXECUTION
  REJECTED
  LOCKED
}

enum DepartmentAccessLevel {
  OWNER
  EDITOR
  REVIEWER
  VIEWER
}

enum AuditAction {
  PLAN_CREATED
  PLAN_UPDATED
  PLAN_DELETED
  STATUS_DRAFT
  STATUS_REVIEW
  STATUS_APPROVED
  STATUS_SUBMITTED
  APPROVAL_COMMENT
  VERSION_SNAPSHOT_SUBMITTED
  VERSION_SNAPSHOT_APPROVED
  EXCEL_IMPORTED
  EXCEL_EXPORTED
  SNAPSHOT_EXPORTED
  PASSWORD_CHANGED
  NOTIFICATION_READ
  EXECUTIVE_REPORT_VIEWED
  USER_LOGIN
  USER_LOGOUT
  USER_CREATED
  USER_UPDATED
  USER_DISABLED
  DEPARTMENT_ACCESS_GRANTED
  DEPARTMENT_ACCESS_REVOKED
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(PLANNER)
  isActive     Boolean  @default(true)

  // If true, user can access every department/cost centre.
  // Usually true only for ADMIN or senior national users.
  canAccessAllDepartments Boolean @default(false)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  lastLoginAt  DateTime?

  ownedPlans           BusinessPlan[]             @relation("BusinessPlanOwner")
  createdPlans         BusinessPlan[]             @relation("BusinessPlanCreatedBy")
  updatedPlans         BusinessPlan[]             @relation("BusinessPlanUpdatedBy")
  auditLogs            AuditLog[]
  sessions             Session[]
  departmentAccess     UserDepartmentAccess[]
  approvalComments     ApprovalComment[]
  versionSnapshots     VersionSnapshot[]
  notifications        Notification[]
  exportHistory        ExportHistory[]

  @@index([role])
  @@index([isActive])
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Department {
  id             String   @id @default(cuid())
  code           String   @unique
  name           String
  organization   String   @default("Ministry of Health")
  facility       String?
  costCenter     String?
  costCenterName String?
  budgetCeilings DepartmentBudgetCeiling[]
  costCenters    CostCenter[]
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  plans          BusinessPlan[]
  userAccess     UserDepartmentAccess[]

  @@index([code])
  @@index([isActive])
}

model UserDepartmentAccess {
  id          String                @id @default(cuid())
  userId      String
  departmentId String
  accessLevel DepartmentAccessLevel @default(VIEWER)
  createdAt   DateTime              @default(now())

  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  department  Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([userId, departmentId])
  @@index([departmentId])
  @@index([accessLevel])
}

model BusinessPlan {
  id             String     @id @default(cuid())
  title          String
  organization   String     @default("Ministry of Health")
  year           Int
  facility       String
  costCenter     String
  costCenterName String
  ceilingAmount  Decimal    @default(0) @db.Decimal(18, 2)
  ceilingJustification String @default("")
  status         PlanStatus @default(DRAFT)

  departmentId   String?
  department     Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  ownerId        String?
  owner          User? @relation("BusinessPlanOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  createdById    String?
  createdBy      User? @relation("BusinessPlanCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  updatedById    String?
  updatedBy      User? @relation("BusinessPlanUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  submittedAt    DateTime?
  approvedAt     DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  activities       Activity[]
  auditLogs        AuditLog[]
  approvalComments ApprovalComment[]
  versionSnapshots VersionSnapshot[]
  notifications    Notification[]
  exportHistory     ExportHistory[]
  commitments       Commitment[]
  expenditures      Expenditure[]
  donorFundAllocations DonorFundAllocation[]

  @@index([year])
  @@index([status])
  @@index([departmentId])
  @@index([costCenter])
  @@index([ownerId])
}

model Activity {
  id                       String       @id @default(cuid())
  businessPlanId           String
  businessPlan             BusinessPlan @relation(fields: [businessPlanId], references: [id], onDelete: Cascade)

  subProgram               String
  corporatePlanKeyActivity String       @default("")
  outputOrServiceTarget    String       @default("")
  targetForYear            String       @default("")
  responsibility           String       @default("")

  activityNumber           String
  activityDescription      String
  jobCode                  String       @default("")
  expenditureDescription   String       @default("")

  estimatedCost            Decimal      @default(0) @db.Decimal(18, 2)
  recurrentBudget          Decimal      @default(0) @db.Decimal(18, 2)
  developmentPartners      Decimal      @default(0) @db.Decimal(18, 2)

  q1                       Boolean      @default(false)
  q2                       Boolean      @default(false)
  q3                       Boolean      @default(false)
  q4                       Boolean      @default(false)

  funding                  String       @default("Recurrent")
  budgetCategory           String       @default("Admin")
  accountCode              String       @default("")
  costCenterCode           String       @default("")
  nsdpTarget               String       @default("")
  activityCategory         String       @default("")
  fundingSourceId          String?
  approvedBudget           Decimal      @default(0) @db.Decimal(18, 2)
  sortOrder                Int          @default(0)

  commitments              Commitment[]
  expenditures             Expenditure[]

  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt

  @@index([businessPlanId])
  @@index([activityNumber])
  @@index([subProgram])
  @@index([sortOrder])
}

model AuditLog {
  id             String       @id @default(cuid())
  businessPlanId String?
  businessPlan   BusinessPlan? @relation(fields: [businessPlanId], references: [id], onDelete: Cascade)

  userId         String?
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  action         String
  details        String       @default("")

  // Optional structured data. Useful for snapshots, imported file metadata,
  // previous/new values, and approval comment payloads.
  metadata       Json?

  createdAt      DateTime     @default(now())

  @@index([businessPlanId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model ApprovalComment {
  id             String       @id @default(cuid())
  businessPlanId String
  businessPlan   BusinessPlan @relation(fields: [businessPlanId], references: [id], onDelete: Cascade)

  userId         String?
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  comment        String
  statusAtTime   PlanStatus?
  createdAt      DateTime     @default(now())

  @@index([businessPlanId])
  @@index([userId])
  @@index([createdAt])
}

model VersionSnapshot {
  id             String       @id @default(cuid())
  businessPlanId String
  businessPlan   BusinessPlan @relation(fields: [businessPlanId], references: [id], onDelete: Cascade)

  capturedById   String?
  capturedBy     User?        @relation(fields: [capturedById], references: [id], onDelete: SetNull)

  status         PlanStatus
  label          String
  snapshot       Json
  createdAt      DateTime     @default(now())

  @@index([businessPlanId])
  @@index([capturedById])
  @@index([status])
  @@index([createdAt])
}



enum FundingSourceType {
  GOVERNMENT_RECURRENT
  GOVERNMENT_DEVELOPMENT
  DONOR_GRANT
  DEVELOPMENT_PARTNER
  OTHER
}

enum FundingConfirmationStatus {
  PENDING
  CONFIRMED
  WITHDRAWN
}

enum CommitmentStatus {
  DRAFT
  COMMITTED
  PARTIALLY_PAID
  PAID
  CANCELLED
}

model ReferenceList {
  id          String          @id @default(cuid())
  key         String          @unique
  name        String
  description String          @default("")
  items       ReferenceItem[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model ReferenceItem {
  id              String        @id @default(cuid())
  referenceListId String
  referenceList   ReferenceList @relation(fields: [referenceListId], references: [id], onDelete: Cascade)
  code            String        @default("")
  label           String
  description     String        @default("")
  category        String        @default("")
  sortOrder       Int           @default(0)
  isActive        Boolean       @default(true)
  metadata        Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([referenceListId])
  @@index([code])
  @@index([category])
  @@index([isActive])
}

model CostCenter {
  id             String      @id @default(cuid())
  code           String      @unique
  name           String
  departmentId   String?
  department     Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  ministryCode   String      @default("MOH")
  facility       String      @default("Vila Central Hospital")
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  allocations    BudgetAllocation[]
  commitments    Commitment[]
  expenditures   Expenditure[]

  @@index([departmentId])
  @@index([isActive])
}

model AccountCode {
  id             String   @id @default(cuid())
  code           String   @unique
  description    String
  budgetCategory String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  allocations    BudgetAllocation[]
  commitments    Commitment[]
  expenditures   Expenditure[]

  @@index([budgetCategory])
  @@index([isActive])
}

model FundingSource {
  id                 String                    @id @default(cuid())
  name               String
  type               FundingSourceType         @default(GOVERNMENT_RECURRENT)
  donorName          String                    @default("")
  confirmationStatus FundingConfirmationStatus @default(CONFIRMED)
  restrictionType    String                    @default("FLEXIBLE")
  allowedCategories  Json?
  startDate          DateTime?
  endDate            DateTime?
  isActive           Boolean                   @default(true)
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  allocations         BudgetAllocation[]
  donorFundAllocations DonorFundAllocation[]

  @@index([type])
  @@index([confirmationStatus])
  @@index([isActive])
}

model MinistryBudget {
  id             String   @id @default(cuid())
  fiscalYear     Int
  ministryCode   String   @default("MOH")
  ministryName   String   @default("Ministry of Health")
  approvedCeiling Decimal @default(0) @db.Decimal(18, 2)
  revisedCeiling  Decimal @default(0) @db.Decimal(18, 2)
  notes          String   @default("")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  departmentCeilings DepartmentBudgetCeiling[]

  @@unique([fiscalYear, ministryCode])
  @@index([fiscalYear])
}

model DepartmentBudgetCeiling {
  id                String        @id @default(cuid())
  fiscalYear        Int
  ministryBudgetId  String?
  ministryBudget    MinistryBudget? @relation(fields: [ministryBudgetId], references: [id], onDelete: SetNull)
  departmentId      String?
  department        Department?   @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  costCenterCode    String
  approvedCeiling   Decimal       @default(0) @db.Decimal(18, 2)
  supplementary     Decimal       @default(0) @db.Decimal(18, 2)
  virementsIn       Decimal       @default(0) @db.Decimal(18, 2)
  virementsOut      Decimal       @default(0) @db.Decimal(18, 2)
  restrictedFunds   Decimal       @default(0) @db.Decimal(18, 2)
  withdrawnFunds    Decimal       @default(0) @db.Decimal(18, 2)
  notes             String        @default("")
  createdById       String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  allocations       BudgetAllocation[]

  @@unique([fiscalYear, costCenterCode])
  @@index([departmentId])
  @@index([fiscalYear])
}

model BudgetAllocation {
  id                        String       @id @default(cuid())
  fiscalYear                Int
  departmentBudgetCeilingId String?
  departmentBudgetCeiling   DepartmentBudgetCeiling? @relation(fields: [departmentBudgetCeilingId], references: [id], onDelete: SetNull)
  costCenterId              String?
  costCenter                CostCenter?  @relation(fields: [costCenterId], references: [id], onDelete: SetNull)
  fundingSourceId           String?
  fundingSource             FundingSource? @relation(fields: [fundingSourceId], references: [id], onDelete: SetNull)
  accountCodeId             String?
  accountCode               AccountCode? @relation(fields: [accountCodeId], references: [id], onDelete: SetNull)
  approvedAmount            Decimal      @default(0) @db.Decimal(18, 2)
  revisedAmount             Decimal      @default(0) @db.Decimal(18, 2)
  availableAmount           Decimal      @default(0) @db.Decimal(18, 2)
  status                    String       @default("ACTIVE")
  notes                     String       @default("")
  createdAt                 DateTime     @default(now())
  updatedAt                 DateTime     @updatedAt

  @@index([fiscalYear])
  @@index([costCenterId])
  @@index([fundingSourceId])
}

model BudgetVirement {
  id                  String   @id @default(cuid())
  fiscalYear          Int
  fromCostCenterCode  String
  toCostCenterCode    String
  fromAccountCode     String   @default("")
  toAccountCode       String   @default("")
  amount              Decimal  @default(0) @db.Decimal(18, 2)
  reason              String
  status              String   @default("PENDING")
  approvedById        String?
  approvedAt          DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([fiscalYear])
  @@index([status])
}

model DonorFundAllocation {
  id               String       @id @default(cuid())
  donorName        String
  fundingSourceId  String?
  fundingSource    FundingSource? @relation(fields: [fundingSourceId], references: [id], onDelete: SetNull)
  businessPlanId   String?
  businessPlan     BusinessPlan? @relation(fields: [businessPlanId], references: [id], onDelete: Cascade)
  activityId       String?
  amount           Decimal      @default(0) @db.Decimal(18, 2)
  confirmedAmount  Decimal      @default(0) @db.Decimal(18, 2)
  pendingAmount    Decimal      @default(0) @db.Decimal(18, 2)
  conditions       String       @default("")
  status           FundingConfirmationStatus @default(PENDING)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([businessPlanId])
  @@index([activityId])
  @@index([status])
}

model Commitment {
  id             String          @id @default(cuid())
  businessPlanId String?
  businessPlan   BusinessPlan?   @relation(fields: [businessPlanId], references: [id], onDelete: Cascade)
  activityId     String?
  activity       Activity?       @relation(fields: [activityId], references: [id], onDelete: SetNull)
  costCenterId   String?
  costCenter     CostCenter?     @relation(fields: [costCenterId], references: [id], onDelete: SetNull)
  costCenterCode String          @default("")
  accountCodeId  String?
  accountCode    AccountCode?    @relation(fields: [accountCodeId], references: [id], onDelete: SetNull)
  accountCodeText String         @default("")
  lpoNumber      String          @default("")
  supplier       String          @default("")
  description    String
  amount         Decimal         @default(0) @db.Decimal(18, 2)
  status         CommitmentStatus @default(COMMITTED)
  committedDate  DateTime        @default(now())
  createdById    String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([businessPlanId])
  @@index([activityId])
  @@index([costCenterCode])
  @@index([status])
}

model Expenditure {
  id              String       @id @default(cuid())
  businessPlanId  String?
  businessPlan    BusinessPlan? @relation(fields: [businessPlanId], references: [id], onDelete: Cascade)
  activityId      String?
  activity        Activity?    @relation(fields: [activityId], references: [id], onDelete: SetNull)
  costCenterId    String?
  costCenter      CostCenter?  @relation(fields: [costCenterId], references: [id], onDelete: SetNull)
  costCenterCode  String       @default("")
  accountCodeId   String?
  accountCode     AccountCode? @relation(fields: [accountCodeId], references: [id], onDelete: SetNull)
  accountCodeText String       @default("")
  voucherNumber   String       @default("")
  invoiceNumber   String       @default("")
  supplier        String       @default("")
  description     String
  amount          Decimal      @default(0) @db.Decimal(18, 2)
  expenditureDate DateTime     @default(now())
  sourceSystem    String       @default("MANUAL")
  createdById     String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([businessPlanId])
  @@index([activityId])
  @@index([costCenterCode])
  @@index([expenditureDate])
}

model ApprovalSnapshot {
  id                 String   @id @default(cuid())
  businessPlanId     String
  snapshotType       String
  status             String
  title              String
  facility           String?
  departmentId       String?
  departmentName     String?
  totalEstimatedCost Float    @default(0)
  recurrentCost      Float    @default(0)
  unfundedCost       Float    @default(0)
  activityCount      Int      @default(0)
  snapshotData       Json
  createdById        String?
  createdByName      String?
  createdByEmail     String?
  createdAt          DateTime @default(now())

  @@index([businessPlanId])
  @@index([snapshotType])
  @@index([status])
  @@index([createdAt])
}


model Notification {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessPlanId String?
  businessPlan   BusinessPlan? @relation(fields: [businessPlanId], references: [id], onDelete: Cascade)
  type           String
  title          String
  message        String
  readAt         DateTime?
  metadata       Json?
  createdAt      DateTime @default(now())

  @@index([userId])
  @@index([businessPlanId])
  @@index([readAt])
  @@index([createdAt])
}

model ExportHistory {
  id             String   @id @default(cuid())
  userId         String?
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  businessPlanId String?
  businessPlan   BusinessPlan? @relation(fields: [businessPlanId], references: [id], onDelete: Cascade)
  snapshotId     String?
  exportType     String
  format         String
  fileName       String
  metadata       Json?
  createdAt      DateTime @default(now())

  @@index([userId])
  @@index([businessPlanId])
  @@index([snapshotId])
  @@index([exportType])
  @@index([createdAt])
}
